{
  "name": "sthlmschack-reimagined",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "translations:check": "tsx scripts/check-translations.ts",
    "generate:changelog": "tsx scripts/generate-changelog.ts",
    "geocode:build": "tsx scripts/build-geocodes.ts",
    "geocode:clubs": "tsx scripts/geocode-clubs.ts",
    "data:clubs": "node scripts/fetch-organizations.js",
    "predev": "node scripts/check-data.js && pnpm generate:changelog",
    "prebuild": "pnpm generate:changelog",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@msvens/schack-se-sdk": "github:msvens/schack-se-sdk#v0.8.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "next": "16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
